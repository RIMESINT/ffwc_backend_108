server {
    server_name www.ffwc.gov.bd ffwc.gov.bd;

    #server_name www.ffwc.gov.bd ffwc.gov.bd;

    # IMPORTANT: Adjust this 'root' path to your frontend's *build* or *dist* directory
    # where your compiled index.html and other static assets reside.
    root /home/rimes/ffwc-rebase/frontend;
    index index.html index.htm; # Ensure index.html is prioritized

    # This location block handles serving static files and SPA client-side routing
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Optional: Add caching for static assets (improve performance)
    location ~* \.(css|js|gif|jpe?g|png|svg|woff|woff2|ttf|eot|ico)$ {
        expires 60d;
        log_not_found off;
        access_log off;
        add_header Cache-Control "public, must-revalidate, proxy-revalidate";
    }

    # Optional: Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Optional: Add basic security headers
    add_header X-Frame-Options "DENY";
    add_header X-Content-Type-Options "nosniff";
    add_header X-XSS-Protection "1; mode=block";
    add_header Referrer-Policy "no-referrer-when-downgrade";

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/ffwc.gov.bd/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/ffwc.gov.bd/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}
server {
    if ($host = www.ffwc.gov.bd) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = ffwc.gov.bd) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80 default_server;
    server_name www.ffwc.gov.bd ffwc.gov.bd;
    return 404; # managed by Certbot

}